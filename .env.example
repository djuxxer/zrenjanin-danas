# =============================================
# Banatski Glas — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# =============================================

# ─── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Site ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://banatskiglas.rs
NEXT_PUBLIC_SITE_NAME=Banatski Glas

# ─── Analytics ──────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=

# ─── Email (for newsletter) ─────────────────
# Using Resend (https://resend.com) — free tier 3000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=newsletter@banatskiglas.rs

# ─── Uploadthing (for image uploads) ────────
# Alternative: use Supabase Storage directly
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxx

# ─── Auth (Supabase handles this automatically) ─
# No additional auth vars needed — Supabase SSR handles sessions

# ─── Development ────────────────────────────
# Set to 'true' to use demo data instead of Supabase
NEXT_PUBLIC_USE_DEMO_DATA=true
